# =====================================================
# Gublu Backend — Environment Variables Template
# =====================================================
#
# 1. Copy this file and rename the copy to: .env
# 2. Paste your real OpenAI API key in place of PASTE_NEW_KEY_HERE
# 3. NEVER commit your .env file to git — it is already in .gitignore
#
# PowerShell (temporary — lasts until you close the terminal):
#   $env:OPENAI_API_KEY = "PASTE_NEW_KEY_HERE"
#
# PowerShell (permanent — survives restarts):
#   [System.Environment]::SetEnvironmentVariable("OPENAI_API_KEY","PASTE_NEW_KEY_HERE","User")
#
# Or set it here (recommended for development):

OPENAI_API_KEY="PASTE_NEW_KEY_HERE"
